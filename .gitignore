# Secrets / live-test artifacts. Live integration tests read credentials
# from env vars; these patterns block accidental commits of dotfiles or
# response dumps that may contain student id, name, session cookies, or
# transcript HTML.
.env
.env.*
*.har
*.dump
nkust_*_dump.txt
nkust_http_log_*.txt

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
android/app/build/

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

